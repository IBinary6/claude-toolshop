{
  "schema_version": 2,
  "modules": {
    "enforcer": true,
    "prompt_inject": true
  },
  "whitelist": {
    "tools": [
      "Agent", "SendMessage",
      "TaskCreate", "TaskUpdate", "TaskList", "TaskGet", "TaskOutput", "TaskStop",
      "AskUserQuestion",
      "EnterPlanMode", "ExitPlanMode",
      "EnterWorktree", "ExitWorktree",
      "Skill", "Workflow",
      "CronCreate", "CronDelete", "CronList", "ScheduleWakeup",
      "Read", "Grep", "Glob", "LSP",
      "Edit", "Write", "MultiEdit", "NotebookEdit",
      "WebFetch", "WebSearch"
    ],
    "mcp_prefixes": [
      "mcp__plugin_context-mode_",
      "mcp__plugin_claude-mem_",
      "mcp__sequential-thinking",
      "mcp__code_review_graph__",
      "mcp__code-review-graph__",
      "mcp__codegraph__",
      "mcp__graphify__"
    ],
    "mcp_block_exact": [
      "mcp__plugin_context-mode_context-mode__ctx_execute",
      "mcp__plugin_context-mode_context-mode__ctx_execute_file",
      "mcp__plugin_context-mode_context-mode__ctx_batch_execute"
    ],
    "bash_safe_heads": [
      "ls", "pwd", "cd",
      "cat", "echo", "which", "where",
      "fd", "rg", "grep", "jq", "delta", "gh", "tsc", "pyright", "pdftotext",
      "head", "tail", "wc", "sort", "uniq",
      "node", "npm", "yarn", "pnpm", "bun",
      "python", "python3", "pip", "pipenv", "poetry",
      "codegraph", "code-review-graph", "graphify",
      "rustc", "cargo",
      "go",
      "java", "javac", "mvn", "gradle",
      "dotnet",
      "ruby", "gem", "bundle",
      "gcc", "g++", "clang", "clang++",
      "cmake", "make", "ninja", "meson",
      "msbuild", "cl",
      "uname", "whoami", "hostname", "printenv"
    ],
    "git_readonly": [
      ["status"], ["diff"], ["log"], ["show"], ["blame"], ["branch"],
      ["rev-parse"], ["rev-list"], ["ls-files"], ["ls-tree"],
      ["describe"], ["reflog"],
      ["remote", "-v"], ["remote", "show"],
      ["config", "--get"], ["config", "--list"],
      ["stash", "list"], ["stash", "show"],
      ["tag", "-l"], ["tag", "--list"]
    ],
    "git_safe_write": [
      "add", "commit", "fetch"
    ],
    "git_dangerous_patterns": [
      "push.*--force", "push.*-f\\b",
      "reset.*--hard",
      "branch.*-D\\b",
      "clean.*(?:^|\\s)-f\\b",
      "clean.*-f[dx]",
      "checkout.*--\\s+\\.",
      "restore.*--\\s+\\."
    ],
    "bash_dangerous_patterns": [
      "^rm\\b",
      "^docker(?:-compose)?\\s+(?:rm|rmi|stop|kill|down|system\\s+prune)\\b",
      "^podman\\s+(?:rm|rmi|stop|kill|system\\s+prune)\\b",
      "^kubectl\\s+(?:delete|apply|patch|replace|scale|drain)\\b",
      "^helm\\s+(?:uninstall|delete|upgrade|install|rollback)\\b"
    ]
  },
  "overrides": {
    "tools_add": [],
    "tools_remove": [],
    "mcp_prefixes_add": [],
    "mcp_block_exact_add": [],
    "mcp_block_exact_remove": [],
    "bash_heads_add": [],
    "bash_heads_remove": []
  }
}
